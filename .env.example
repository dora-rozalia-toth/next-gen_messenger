# Copy to server/.env. Never commit the real file.

# --- AWS Bedrock access ---
# PREFERRED: use a short-lived AWS SSO profile, not long-lived access keys.
AWS_REGION=us-west-2
AWS_PROFILE=your_sso_profile_here

# Only if SSO is not an option — long-lived keys are discouraged. If you must,
# scope the IAM policy to bedrock:InvokeModel on the specific model ARN only.
# Do NOT attach AmazonBedrockFullAccess.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- API gating ---
# Shared secret required on every /api/* request. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Put the same value in the frontend .env as VITE_API_SECRET.
API_SHARED_SECRET=

# Server binds to loopback only — this process proxies a Diligent AWS account.
SERVER_HOST=127.0.0.1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
